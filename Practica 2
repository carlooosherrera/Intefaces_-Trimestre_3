#include "BluetoothSerial.h"

#if !defined(CONFIG_BT_ENABLED) || !defined(CONFIG_BLUEDROID_ENABLED)
#error Bluetooth is not enabled! Please run `make menuconfig` to and enable it
#endif

BluetoothSerial SerialBT;

const int ledPin = 5; // Pin del LED (puedes cambiarlo)

String mensaje = "";

void setup() {
  Serial.begin(115200);
  SerialBT.begin("Carlinhox23_ESP32"); // Nombre del Bluetooth
  
  pinMode(ledPin, OUTPUT);
  digitalWrite(ledPin, LOW);

  Serial.println("Dispositivo listo, conecta por Bluetooth");
}

void loop() {
  // Leer datos desde Bluetooth
  while (SerialBT.available()) {
    char c = SerialBT.read();

    if (c == '\n') {
      mensaje.trim(); // limpiar espacios

      Serial.println("Mensaje recibido: " + mensaje);

      if (mensaje == "Hola") {
        digitalWrite(ledPin, HIGH);
        SerialBT.println("LED ENCENDIDO");
      }
      else if (mensaje == "Adios") {
        digitalWrite(ledPin, LOW);
        SerialBT.println("LED APAGADO");
      }

      mensaje = ""; // limpiar mensaje
    } else {
      mensaje += c;
    }
  }

  delay(20);
}